# Placeholder .env file for collector runtime

# Port the collector listens on. The server must use the same COLLECTOR_PORT value when running services separately.
# COLLECTOR_PORT=8888

# This enables HTTP request/response logging in development. Set value to truthy string to enable, leave empty value or comment out to disable
# ENABLE_HTTP_LOGGER=""
# This enables timestamps for the HTTP Logger. Set value to true to enable, leave empty or comment out to disable
# ENABLE_HTTP_LOGGER_TIMESTAMPS=""

# AMAdocs: local AI runtime + vision model used to caption images so text-less
# pictures become searchable. VisionCaption also falls back to OLLAMA_HOST or the
# local default, so these are belt-and-suspenders for the dev stack.
OLLAMA_BASE_PATH='http://127.0.0.1:11434'
VISION_MODEL_PREF='moondream'

# AMAdocs: "catalog card" summary (~120 words) of a document, stored as `aiSummary`.
# This is now the DEFAULT at ingest (the "AI librarian" reframe): every dropped file
# is cataloged with a bounded summary and ONLY that summary is embedded for search;
# full-text "Deep search" is opt-in per file (right-click). Only a capped leading
# slice (~first 5 pages / 8000 chars) is read, so the per-file cost stays bounded.
# Set DOC_SUMMARY_ENABLED=false to turn cataloging off. Model: SUMMARY_MODEL_PREF →
# OLLAMA_MODEL_PREF (no extra download — it's the chat model).
# DOC_SUMMARY_ENABLED=true
# SUMMARY_MODEL_PREF=phi3.5

# AMAdocs: rasterization DPI for scanned-PDF OCR. Default 150 (clamped to 72-300).
# Higher = sharper small print but slower + more memory; lower it on low-RAM machines.
# OCR_PDF_DPI=150

# AMAdocs: minimum mean OCR confidence (0-100) for an image's text to be treated
# as real. Text-less photos make Tesseract hallucinate glyph noise (~28-40);
# genuine text scores ~85-95. Below this the OCR text is discarded as noise (the
# vision caption still carries the image). Default 50 (clamped 0-100); 0 disables.
# OCR_MIN_CONFIDENCE=50
